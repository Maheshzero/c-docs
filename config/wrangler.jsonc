{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "oslab",
  "main": "../src/middleware/_middleware.js",
  "compatibility_date": "2026-07-16",
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  },
  "assets": {
    "binding": "ASSETS",
    "directory": "../dist",
    "run_worker_first": true
  },
  "vars": {
    "ENVIRONMENT": "production",
    "LOG_LEVEL": "warn"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
