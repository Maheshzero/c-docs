{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "oslab",
  "main": "functions/_middleware.js",
  "compatibility_date": "2026-07-16",
  "observability": {
    "enabled": true
  },
  "assets": {
    "binding": "ASSETS",
    "directory": "dist"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
